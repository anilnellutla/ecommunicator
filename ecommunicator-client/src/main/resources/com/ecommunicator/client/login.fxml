<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ecommunicator.client.ui.LoginController"
      styleClass="login-root"
      alignment="CENTER"
      spacing="0"
      prefWidth="520" prefHeight="620">

    <!-- Logo / Header -->
    <VBox styleClass="login-header" alignment="CENTER" spacing="8">
        <Label text="eCommunicator" styleClass="app-title"/>
        <Label text="Real-time collaboration platform" styleClass="app-subtitle"/>
    </VBox>

    <!-- Form card -->
    <VBox styleClass="login-card" spacing="16" maxWidth="400">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <Label text="Server URL" styleClass="field-label"/>
        <TextField fx:id="serverUrlField"
                   promptText="ws://localhost:8080/ws-native"
                   text="ws://localhost:8080/ws-native"
                   styleClass="text-field"/>

        <Label text="Your Display Name" styleClass="field-label"/>
        <TextField fx:id="displayNameField"
                   promptText="e.g. Alice"
                   styleClass="text-field"/>

        <Label text="Session ID" styleClass="field-label"/>
        <TextField fx:id="sessionIdField"
                   promptText="mtg-abc123 (leave blank to auto-generate)"
                   styleClass="text-field"/>

        <Label text="Session Password (optional)" styleClass="field-label"/>
        <PasswordField fx:id="sessionPasswordField"
                       promptText="Leave blank for open session"
                       styleClass="text-field"/>

        <HBox spacing="12" alignment="CENTER">
            <Button fx:id="createSessionBtn"
                    text="Create Session"
                    styleClass="btn-primary"
                    onAction="#onCreateSession"
                    prefWidth="160"/>
            <Button fx:id="joinSessionBtn"
                    text="Join Session"
                    styleClass="btn-secondary"
                    onAction="#onJoinSession"
                    prefWidth="160"/>
        </HBox>

        <HBox alignment="CENTER" spacing="8">
            <ProgressIndicator fx:id="progressIndicator" prefWidth="24" prefHeight="24"/>
            <Label fx:id="statusLabel" styleClass="status-label"/>
        </HBox>
    </VBox>

    <Label text="v2.0 — Whiteboard • Video • Chat • Polls" styleClass="footer-label"/>
</VBox>
