<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ecommunicator.client.ui.MainController"
            fx:id="rootPane"
            styleClass="main-root">

    <!-- ══════════════════════════════════════════════════════════════
         TOP TOOLBAR
         ══════════════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="top-toolbar" spacing="8" alignment="CENTER_LEFT">
            <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>

            <!-- Session info -->
            <Label fx:id="sessionIdLabel" styleClass="session-label"/>
            <Region HBox.hgrow="ALWAYS"/>

            <!-- Controls -->
            <Button fx:id="micBtn"        text="🎙️ Unmute"      styleClass="btn-muted"   onAction="#onToggleMic"/>
            <Button fx:id="cameraBtn"     text="📷 Start Video"  styleClass="btn-muted"   onAction="#onToggleCamera"/>
            <Button fx:id="screenShareBtn" text="🖥️ Share Screen" styleClass="btn-default" onAction="#onToggleScreenShare"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="handBtn"       text="✋ Raise Hand"   styleClass="btn-default" onAction="#onRaiseHand"/>
            <Button fx:id="pollBtn"       text="📊 Poll"         styleClass="btn-default" onAction="#onCreatePoll"/>
            <Button fx:id="recordBtn"     text="⏺️ Record"       styleClass="btn-default" onAction="#onToggleRecord"/>
            <Separator orientation="VERTICAL"/>
            <ToggleButton fx:id="showParticipantsBtn" text="👥 Participants" styleClass="btn-toggle"
                          onAction="#onToggleParticipants"/>
            <ToggleButton fx:id="showChatBtn" text="💬 Chat" styleClass="btn-toggle"
                          onAction="#onToggleChat"/>
            <Separator orientation="VERTICAL"/>
            <Button fx:id="leaveBtn" text="🚪 Leave" styleClass="btn-danger" onAction="#onLeave"/>
        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════════
         CENTER — Main content area
         ══════════════════════════════════════════════════════════════ -->
    <center>
        <SplitPane orientation="HORIZONTAL" dividerPositions="0.75">

            <!-- Left: Whiteboard / Media -->
            <VBox styleClass="content-area" SplitPane.resizableWithParent="true">

                <!-- Sub-tabs: Whiteboard | Screen Share | Video -->
                <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">

                    <!-- Whiteboard tab -->
                    <Tab text="📋 Whiteboard">
                        <VBox spacing="0">
                            <!-- Page tabs -->
                            <HBox fx:id="pageTabBar" styleClass="page-tab-bar" spacing="4" alignment="CENTER_LEFT">
                                <padding><Insets top="4" right="8" bottom="4" left="8"/></padding>
                                <Button text="＋ Page" styleClass="btn-add-page" onAction="#onAddPage"/>
                            </HBox>

                            <!-- Drawing area -->
                            <StackPane fx:id="whiteboardArea" styleClass="whiteboard-area" VBox.vgrow="ALWAYS">
                                <Pane fx:id="textOverlayPane" mouseTransparent="true"
                                      style="-fx-background-color: transparent;"/>
                            </StackPane>

                            <!-- Drawing tools palette -->
                            <HBox fx:id="toolPalette" styleClass="tool-palette" spacing="4" alignment="CENTER_LEFT">
                                <padding><Insets top="6" right="12" bottom="6" left="12"/></padding>
                                <Button fx:id="penBtn"     styleClass="tool-btn" onAction="#onSelectPen">
                                    <graphic><FontIcon iconLiteral="fas-pen"        iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Pen"/></tooltip></Button>
                                <Button fx:id="rectBtn"    styleClass="tool-btn" onAction="#onSelectRect">
                                    <graphic><FontIcon iconLiteral="fas-square"     iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Rectangle"/></tooltip></Button>
                                <Button fx:id="ellipseBtn" styleClass="tool-btn" onAction="#onSelectEllipse">
                                    <graphic><FontIcon iconLiteral="fas-circle"     iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Ellipse"/></tooltip></Button>
                                <Button fx:id="lineBtn"    styleClass="tool-btn" onAction="#onSelectLine">
                                    <graphic><FontIcon iconLiteral="fas-minus"      iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Line"/></tooltip></Button>
                                <Button fx:id="arrowBtn"   styleClass="tool-btn" onAction="#onSelectArrow">
                                    <graphic><FontIcon iconLiteral="fas-arrow-right" iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Arrow"/></tooltip></Button>
                                <Button fx:id="textBtn"    styleClass="tool-btn" onAction="#onSelectText">
                                    <graphic><FontIcon iconLiteral="fas-font"       iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Text"/></tooltip></Button>
                                <Button fx:id="eraserBtn"  styleClass="tool-btn" onAction="#onSelectEraser">
                                    <graphic><FontIcon iconLiteral="fas-eraser"     iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Eraser"/></tooltip></Button>
                                <Separator orientation="VERTICAL"/>
                                <Button styleClass="tool-btn" onAction="#onUndoClicked">
                                    <graphic><FontIcon iconLiteral="fas-undo"       iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Undo"/></tooltip></Button>
                                <Button styleClass="tool-btn" onAction="#onRedoClicked">
                                    <graphic><FontIcon iconLiteral="fas-redo"       iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Redo"/></tooltip></Button>
                                <Button styleClass="tool-btn-danger" onAction="#onClearPage">
                                    <graphic><FontIcon iconLiteral="fas-trash-alt"  iconSize="15"/></graphic>
                                    <tooltip><Tooltip text="Clear page"/></tooltip></Button>
                                <Separator orientation="VERTICAL"/>
                                <ColorPicker fx:id="colorPicker" styleClass="color-picker"/>
                                <Label text="Size:"/>
                                <Slider fx:id="brushSizeSlider" prefWidth="80"/>
                            </HBox>
                        </VBox>
                    </Tab>

                    <!-- Screen Share Viewer tab -->
                    <Tab text="🖥️ Screen">
                        <StackPane fx:id="mediaArea" styleClass="media-area">
                            <ImageView fx:id="screenShareViewer"
                                       preserveRatio="true"
                                       fitWidth="1024" fitHeight="768"/>
                        </StackPane>
                    </Tab>

                    <!-- Video Grid tab -->
                    <Tab text="🎥 Video">
                        <ScrollPane fitToWidth="true" fitToHeight="true">
                            <GridPane fx:id="videoGrid" styleClass="video-grid"
                                      hgap="8" vgap="8">
                                <padding><Insets topRightBottomLeft="16"/></padding>
                            </GridPane>
                        </ScrollPane>
                    </Tab>

                </TabPane>
            </VBox>

            <!-- Right: Participants + Chat -->
            <VBox styleClass="side-panel" minWidth="260" maxWidth="340">

                <!-- Participants -->
                <VBox fx:id="participantsPanel" VBox.vgrow="SOMETIMES" styleClass="panel-section">
                    <Label text="👥 Participants" styleClass="panel-title"/>
                    <ListView fx:id="participantsListView" VBox.vgrow="ALWAYS" styleClass="participants-list"/>
                </VBox>

                <!-- Chat -->
                <VBox fx:id="chatPanel" VBox.vgrow="ALWAYS" styleClass="panel-section">
                    <Label text="💬 Chat" styleClass="panel-title"/>
                    <ListView fx:id="chatListView" VBox.vgrow="ALWAYS" styleClass="chat-list"/>
                    <HBox spacing="6" alignment="CENTER">
                        <padding><Insets top="6"/></padding>
                        <TextField fx:id="chatInput" HBox.hgrow="ALWAYS"
                                   promptText="Type a message…"
                                   styleClass="chat-input"
                                   onKeyPressed="#onChatInputKeyPressed"/>
                        <Button fx:id="chatSendBtn" text="Send"
                                styleClass="btn-primary" onAction="#onChatSend"/>
                    </HBox>
                </VBox>

            </VBox>
        </SplitPane>
    </center>

</BorderPane>
